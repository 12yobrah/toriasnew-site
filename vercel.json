{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/wp-content/:path*",
      "destination": "https://backend.toriasglamhaven.co.ke/wp-content/:path*"
    },
    {
      "source": "/wp-includes/:path*",
      "destination": "https://backend.toriasglamhaven.co.ke/wp-includes/:path*"
    },
    {
      "source": "/wp-json/:path*",
      "destination": "https://backend.toriasglamhaven.co.ke/wp-json/:path*"
    },
    {
      "source": "/backend/:path*",
      "destination": "https://backend.toriasglamhaven.co.ke/:path*"
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "https://backend.toriasglamhaven.co.ke/wp-admin/:path*"
    },
    {
      "source": "/wp-login.php",
      "destination": "https://backend.toriasglamhaven.co.ke/wp-login.php"
    }
  ]
}
